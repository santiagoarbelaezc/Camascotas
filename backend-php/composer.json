{
    "name": "camascotas/backend-php",
    "description": "Camascotas API Backend - PHP REST API con JWT y Cloudinary",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^6.10",
        "cloudinary/cloudinary_php": "^2.13"
    },
    "config": {
        "allow-plugins": {
            "cloudinary/cloudinary_php": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "./"
        }
    },
    "authors": [
        {
            "name": "Camascotas"
        }
    ]
}
